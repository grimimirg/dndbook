# Docker Compose Environment Variables
# 
# This file configures docker-compose.standalone.yaml
# ALL VARIABLES ARE REQUIRED - the script will fail if any are missing
#
# To use: 
#   1. cp .env.example .env
#   2. Edit .env with your values
#   3. Run: ./start-docker.sh

# PostgreSQL Configuration
POSTGRES_USER=dndbook_user
POSTGRES_PASSWORD=dndbook_password
POSTGRES_DB=dndbook_db

# Security Keys - CHANGE THESE IN PRODUCTION!
# Generate new keys with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# Default Admin Password
ADMIN_PASSWORD=admin123

# Backend Configuration
MOCK_DATA=false
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
POSTS_PER_PAGE=10

# Frontend Configuration
# Leave VITE_API_URL empty for standalone mode (nginx proxy handles it)
VITE_API_URL=
VITE_MOCK_DATA=false
VITE_AVAILABLE_LOCALES=en,it,de,es,fr
VITE_POSTS_PER_PAGE=10
VITE_POST_PREVIEW_LIMIT=200
