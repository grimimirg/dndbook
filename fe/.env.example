# Backend API URL
# For local development: http://localhost:5000
# For docker-compose standalone: leave empty (nginx proxy handles it)
VITE_API_URL=

# Mock Data Mode (true/false)
VITE_MOCK_DATA=false

# Comma-separated list of available locale codes
# Must match the .yaml filenames in src/locales/
VITE_AVAILABLE_LOCALES=en,it,de,es,fr

# Pagination Configuration
VITE_POSTS_PER_PAGE=10

# Post preview character limit
VITE_POST_PREVIEW_LIMIT=200
