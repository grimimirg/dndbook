# Database Configuration
# For PostgreSQL with Docker (after running setup-postgres.sh):
DATABASE_URL=postgresql://dndbook_user:dndbook_password@localhost:5432/dndbook_db
# For other PostgreSQL instances, adjust the connection string accordingly

# Application Configuration
FLASK_APP=main.py
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# Mock Data (set to false to use real database)
MOCK_DATA=false

# Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Pagination
POSTS_PER_PAGE=10

# Default Admin User
ADMIN_PASSWORD=admin123
